# ============================================================================
# Blood Chain Pakistan — environment configuration
# Copy to `.env` and fill in real values. `.env` is gitignored.
# RULE: only variables prefixed with VITE_ are bundled into the browser.
#       Everything else here is documentation for SERVER-ONLY secrets that must
#       NOT live in this file or in git — see the bottom section.
# ============================================================================

# ── Frontend (safe to expose — shipped to the browser) ──────────────────────
# Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# Publishable ("anon") key — designed to be public; access is gated by RLS.
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# SERVER-ONLY SECRETS — never put these in this file, in any VITE_ var, or in git.
# They are NOT used by the browser. Set them on Edge Functions with:
#     npx supabase secrets set NAME="value"
# (Listed here only so you know what to obtain.)
# ============================================================================

# Database password — used ONLY by the Supabase CLI for `link` / `db push`.
# The CLI prompts for it; do not store it in the repo. (Optionally, for one shell
# session only:  PowerShell →  $env:SUPABASE_DB_PASSWORD="..." )
SUPABASE_DB_PASSWORD=

# Supabase SECRET key — full DB access, bypasses RLS. Edge Functions only (Sprint 5).
# Dashboard → Project Settings → API → secret key (sb_secret_...)
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# WhatsApp Cloud API (Sprint 5) — Edge Function secrets:
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
#   WHATSAPP_VERIFY_TOKEN=          # you invent this string; Meta echoes it on webhook setup

# Cloudflare Turnstile SECRET key (server-side verification of the site token):
TURNSTILE_SECRET_KEY=
