# Blood Chain Pakistan — WhatsApp bot (pilot) configuration.
# Copy to .env and fill in. NEVER commit .env.

# Supabase project URL (same as the frontend's VITE_SUPABASE_URL)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Supabase SECRET / service-role key (server-side only — bypasses RLS).
# Dashboard → Project Settings → API → service_role secret. NEVER ship to a browser.
SUPABASE_SERVICE_ROLE_KEY=

# How often (ms) to poll for new 'open' blood requests.
POLL_INTERVAL_MS=20000

# Match radius (metres) and max donors to alert per request.
MATCH_RADIUS_M=50000
MAX_DONORS_PER_REQUEST=10

# Safety: when true, the bot LOGS messages instead of sending them. Start here.
DRY_RUN=true

# Optional: path Puppeteer should use for Chrome/Chromium (leave blank to use the
# bundled one). On a small VPS you may point this at an installed chromium.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
